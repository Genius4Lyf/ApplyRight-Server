MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/applyright
JWT_SECRET=your_jwt_secret_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
AI_PROVIDER=gemini
ADMIN_SECRET_KEY=secret_key_to_register_admins
FRONTEND_URL=http://localhost:5173
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome

# Flutterwave one-time payments. Get keys from the Flutterwave dashboard (use TEST
# keys locally). FLW_SECRET_HASH is the "Secret hash" you set under Settings →
# Webhooks; it must match the value Flutterwave sends in the verif-hash header.
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx
FLW_SECRET_HASH=choose_a_long_random_string
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# Live interview model + cost controls (see CLAUDE.md). mini is ~3-4x cheaper.
REALTIME_MODEL=gpt-realtime-mini
REALTIME_MAX_SESSION_SEC=360
